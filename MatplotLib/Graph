import matplotlib.pyplot as plt

months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"]
sales = [1000, 1500, 1200, 1700, 2000, 2200, 2500, 2400, 2300, 2100, 1900, 1800]

plt.plot(months,sales, marker="o")
plt.title("MOnthly Sales")
plt.xlabel("Months")
plt.ylabel("Sales ($)")
print(len(months))
print(len(sales))
plt.grid(True)

plt.show()